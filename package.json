{
  "name": "libraryhub",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
    "seed": "npm run seed --workspace=server"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
