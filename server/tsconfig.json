{
      "compilerOptions": {
              "target": "ES2020",
              "module": "commonjs",
              "lib": ["ES2020"],
              "rootDir": "./src",
              "outDir": "./dist",
              "strict": true,
              "esModuleInterop": true,
              "skipLibCheck": true,
              "forceConsistentCasingInFileNames": true,
              "resolveJsonModule": true,
              "baseUrl": ".",
              "paths": {
                        "@libraryhub/shared": ["../shared/types/index.ts"]
              },
              "ignoreDeprecations": "6.0"
      },
      "include": ["src/**/*"],
      "exclude": ["node_modules", "dist"]
}
